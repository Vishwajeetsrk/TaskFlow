<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Us | TaskFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/dashboard"><i class="fas fa-layer-group me-2"></i>TaskFlow</a>
            <div class="d-flex gap-3 align-items-center">
                <a href="/about" class="text-white text-decoration-none small">About</a>
                <a href="/contact" class="text-white text-decoration-none small">Contact</a>
                
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="darkModeToggle" onchange="toggleDarkMode()">
                    <label class="form-check-label" for="darkModeToggle"><i class="fas fa-moon text-white"></i></label>
                </div>
                <a href="/settings" class="text-white"><i class="fas fa-cog"></i></a>
                <a href="/logout" class="btn btn-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass p-5 rounded-xl text-center">
                    <h1 class="fw-bold mb-4 text-primary"><i class="fas fa-envelope me-3"></i>Contact Us</h1>
                    <p class="lead mb-5">Have a question or feedback? We'd love to hear from you.</p>
                    
                    <div class="row text-start justify-content-center">
                        <div class="col-md-6 mb-4">
                            <div class="card border-0 shadow-sm p-4 h-100">
                                <h5 class="text-primary mb-3"><i class="fas fa-user me-2"></i>Vishwajeet</h5>
                                <p class="mb-2" style="color: #1388ef;"><strong>Email:</strong> <a href="mailto:Vishwajeet@sadc.edu.in">Vishwajeet@sadc.edu.in</a></p>
                                <p class="mb-0" style="color: #1388ef;"><strong>Role:</strong> Developer & Designer</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="card border-0 shadow-sm p-4 h-100 bg-primary text-white">
                                <h5 class="mb-3"><i class="fas fa-info-circle me-2"></i>Support</h5>
                                <p class="small">For technical issues, please contact us via email. We typically respond within 24 hours.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer py-4 text-center mt-5">
        <div class="container">
            <span class="text-muted small">© 2026 TaskFlow. Built by Vishwajeet.</span>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>