<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us | TaskFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/dashboard"><i class="fas fa-layer-group me-2"></i>TaskFlow</a>
            <div class="d-flex gap-3 align-items-center">
                <a href="/about" class="text-white text-decoration-none small">About</a>
                <a href="/contact" class="text-white text-decoration-none small">Contact</a>
                
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="darkModeToggle" onchange="toggleDarkMode()">
                    <label class="form-check-label" for="darkModeToggle"><i class="fas fa-moon text-white"></i></label>
                </div>
                <a href="/settings" class="text-white"><i class="fas fa-cog"></i></a>
                <a href="/logout" class="btn btn-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass p-5 rounded-xl text-center">
                    <h1 class="fw-bold mb-4 text-primary">🚀 About TaskFlow</h1>
                    <p class="lead mb-5">A Smart Task Management System built with modern web technologies to help you achieve your goals efficiently.</p>
                    
                    <div class="row text-start">
                        <div class="col-md-6 mb-4">
                            <h4><i class="fas fa-bullseye text-danger me-2"></i>Mission</h4>
                            <p>To help students and professionals manage their daily tasks efficiently with gamification and AI assistance. We believe organizing your life should be fun and rewarding.</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <h4><i class="fas fa-tools text-success me-2"></i>Built With</h4>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="fab fa-node-js me-2"></i>Node.js & Express.js</li>
                                <li class="mb-2"><i class="fas fa-database me-2"></i>MongoDB Atlas</li>
                                <li class="mb-2"><i class="fab fa-bootstrap me-2"></i>Bootstrap 5</li>
                                <li class="mb-2"><i class="fas fa-brain me-2"></i>EJS Templating</li>
                            </ul>
                        </div>
                    </div>

                    <hr class="my-4">
                    
                    <h5 class="mt-4">How To Use</h5>
                    <div class="d-flex justify-content-center gap-4 mt-3 text-muted">
                        <span><strong>1.</strong> Signup</span>
                        <span><strong>2.</strong> Create Task</span>
                        <span><strong>3.</strong> Complete & Earn Points</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Footer -->
    <footer class="footer py-4 text-center mt-5">
        <div class="container">
            <span class="text-muted small">© 2026 TaskFlow. Built by Vishwajeet.</span>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>