<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile | TaskFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/dashboard"><i class="fas fa-layer-group me-2"></i>TaskFlow</a>
            <div class="d-flex gap-3 align-items-center">
                <a href="/about" class="text-white small">About</a>
                <a href="/contact" class="text-white small">Contact</a>
                
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="darkModeToggle" onchange="toggleDarkMode()">
                    <label class="form-check-label" for="darkModeToggle"><i class="fas fa-moon text-white"></i></label>
                </div>
                <a href="/settings" class="text-white"><i class="fas fa-cog"></i></a>
                <a href="/logout" class="btn btn-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Profile Header Card -->
                <div class="glass p-5 rounded-xl text-center mb-4 position-relative overflow-hidden">
                    <div class="profile-avatar mb-3">
                        <%= user.name.charAt(0) %>
                    </div>
                    <h2 class="fw-bold mb-1"><%= user.name %></h2>
                    <p class="text-muted mb-3"><%= user.email %></p>
                    
                    <!-- BIO DISPLAY FIX -->
                    <p class="lead mt-3 w-75 mx-auto text-break" style="white-space: pre-wrap;"><%= user.bio %></p>
                    
                    <div class="d-flex justify-content-center gap-4 mt-4">
                        <div class="text-center">
                            <h4 class="fw-bold text-primary mb-0"><%= user.totalTasks %></h4>
                            <small class="text-muted">Tasks</small>
                        </div>
                        <div class="text-center">
                            <h4 class="fw-bold text-warning mb-0"><%= user.points %></h4>
                            <small class="text-muted">Points</small>
                        </div>
                    </div>
                    
                    <a href="/settings" class="btn btn-outline-primary mt-4 px-4">
                        <i class="fas fa-edit me-2"></i>Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>